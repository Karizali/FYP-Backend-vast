# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# ─── MongoDB ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/gaussian_db

# ─── Redis ────────────────────────────────────────────
REDIS_URL="redis://default:jbhnsbdcnsbdnb@redis-111.c10.us-east-1-2.ec2.cloud.redislabs.com:111"

# ─── Cloudinary (Free tier: 25GB storage, 25GB bandwidth/month) ───────────────
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Runpod ───────────────────────────────────────────
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_endpoint_id
RUNPOD_WEBHOOK_SECRET=your_webhook_secret

# ─── Firebase (FCM Push Notifications) ───────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Layer 2 — Worker & Runpod ────────────────────────────────────────────────
# Public URL of your API server (Runpod uses this to call back your webhook)
API_BASE_URL=https://your-app.railway.app

# Runpod Serverless
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_endpoint_id
RUNPOD_WEBHOOK_SECRET=any_random_secret_string

# Worker config
WORKER_CONCURRENCY=1
RUNPOD_POLL_INTERVAL_MS=15000
RUNPOD_POLL_TIMEOUT_MS=2400000

WORKER_SECRET="secret"

WORK_DIR="/workspace"